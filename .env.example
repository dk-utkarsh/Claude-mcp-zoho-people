# Zoho People MCP Server — Vercel Environment Variables
# Add these in Vercel Dashboard → Settings → Environment Variables

# Required: Zoho region — com (US), eu (Europe), in (India), com.au (Australia), jp (Japan)
ZOHO_DOMAIN=in

# Optional: server-stored Zoho OAuth credentials.
# When BOTH are set, the connector is zero-config for users — they don't need to
# paste Client ID/Secret into Claude's Advanced Settings. The server injects
# these into every OAuth request automatically.
# ZOHO_CLIENT_ID=1000.XXXXXXXXXXXXXXXXXXXXXXXXXXXX
# ZOHO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: explicit public URL (auto-detected from request headers if not set)
# PUBLIC_URL=https://your-app.vercel.app

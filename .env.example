# Zoho People MCP Server — Vercel Environment Variables
# Add these in Vercel Dashboard → Settings → Environment Variables

# Zoho region: com (US), eu (Europe), in (India), com.au (Australia), jp (Japan)
ZOHO_DOMAIN=in

# Optional: explicit public URL (auto-detected from request if not set)
# PUBLIC_URL=https://your-app.vercel.app
